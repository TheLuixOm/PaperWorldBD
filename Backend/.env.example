# Backend env vars (copia esto a .env y ajusta valores)
PORT=3001
# Opción A (recomendada): una sola URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/paperworld

# Opción B (si no usas DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=paperworld

JWT_SECRET=cambia-este-secreto
# Si usas proxy de Vite, CORS no es necesario. Si NO usas proxy:
CORS_ORIGIN=http://localhost:5173
